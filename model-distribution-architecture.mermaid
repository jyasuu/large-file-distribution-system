flowchart TB
    subgraph EXTERNAL["рџЊђ  External"]
        REPO[("Model Repository\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Source of truth\nвЂў Versioned model files")]
    end

    subgraph CLUSTER["рџЏў  Data Center Cluster"]
        direction TB

        subgraph CONTROL["Control Plane"]
            TRACKER["рџЋЇ  Centralized Tracker\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Global chunk bitmap\nвЂў Bandwidth state / node\nвЂў Peer-selection engine\nвЂў Rarity-First / Topo-Aware\nвЂў Job lifecycle management"]
