        subgraph DATA["Data Plane"]
            direction LR

            subgraph RACK1["Rack A"]
                SEED["рџЊ±  Seed Node\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў First full download\nвЂў Seeds all peers\nвЂў Reports bitmap"]
                N1["Node A-2\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Partial chunks\nвЂў Upload в†” Download\nвЂў 10 Gbps each"]
                N2["Node A-3\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Partial chunks\nвЂў Upload в†” Download\nвЂў 10 Gbps each"]
            end

            subgraph RACK2["Rack B"]
                N3["Node B-1\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Partial chunks\nвЂў Upload в†” Download\nвЂў 10 Gbps each"]
                N4["Node B-2\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Partial chunks\nвЂў Upload в†” Download\nвЂў 10 Gbps each"]
                N5["Node B-3\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Partial chunks\nвЂў Upload в†” Download\nвЂў 10 Gbps each"]
